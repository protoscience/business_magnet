[Unit]
Description=Trading Agent - LLM scan (Mon-Fri, every 15 min during RTH)

[Timer]
# 25 firings per trading day: 09:35, 09:50, ..., 15:35, 15:45 ET
# OnCalendar runs in system TZ; we set America/New_York explicitly.
# Script also has a market-hours guard via Alpaca's clock — this handles
# holidays + half-days so the timer doesn't need to.
OnCalendar=Mon..Fri *-*-* 09:35:00 America/New_York
OnCalendar=Mon..Fri *-*-* 09:50:00 America/New_York
OnCalendar=Mon..Fri *-*-* 10:05:00 America/New_York
OnCalendar=Mon..Fri *-*-* 10:20:00 America/New_York
OnCalendar=Mon..Fri *-*-* 10:35:00 America/New_York
OnCalendar=Mon..Fri *-*-* 10:50:00 America/New_York
OnCalendar=Mon..Fri *-*-* 11:05:00 America/New_York
OnCalendar=Mon..Fri *-*-* 11:20:00 America/New_York
OnCalendar=Mon..Fri *-*-* 11:35:00 America/New_York
OnCalendar=Mon..Fri *-*-* 11:50:00 America/New_York
OnCalendar=Mon..Fri *-*-* 12:05:00 America/New_York
OnCalendar=Mon..Fri *-*-* 12:20:00 America/New_York
OnCalendar=Mon..Fri *-*-* 12:35:00 America/New_York
OnCalendar=Mon..Fri *-*-* 12:50:00 America/New_York
OnCalendar=Mon..Fri *-*-* 13:05:00 America/New_York
OnCalendar=Mon..Fri *-*-* 13:20:00 America/New_York
OnCalendar=Mon..Fri *-*-* 13:35:00 America/New_York
OnCalendar=Mon..Fri *-*-* 13:50:00 America/New_York
OnCalendar=Mon..Fri *-*-* 14:05:00 America/New_York
OnCalendar=Mon..Fri *-*-* 14:20:00 America/New_York
OnCalendar=Mon..Fri *-*-* 14:35:00 America/New_York
OnCalendar=Mon..Fri *-*-* 14:50:00 America/New_York
OnCalendar=Mon..Fri *-*-* 15:05:00 America/New_York
OnCalendar=Mon..Fri *-*-* 15:20:00 America/New_York
OnCalendar=Mon..Fri *-*-* 15:35:00 America/New_York
AccuracySec=5s
Persistent=false
Unit=trading-auto-scan.service

[Install]
WantedBy=timers.target
