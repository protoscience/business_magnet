ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
SEARXNG_URL=http://localhost:8080
CLAUDE_CODE_USE_SUBSCRIPTION=1
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
# Guild (server) allowlist. Empty = DM-only; the bot auto-leaves any guild
# it's invited to or is currently sitting in. Keep this empty unless you
# explicitly want SuperSonic active in a server.
DISCORD_ALLOWED_GUILD_IDS=

# Grafana (optional, defaults to localhost-only).
# Set GRAFANA_BIND=0.0.0.0 to expose on your LAN. Set GRAFANA_ROOT_URL to
# the reachable address so Grafana's share-links point at the right host.
# Example for a LAN-exposed host:
#   GRAFANA_BIND=0.0.0.0
#   GRAFANA_ROOT_URL=http://192.168.1.110:3000
GRAFANA_BIND=127.0.0.1
GRAFANA_ROOT_URL=http://localhost:3000
